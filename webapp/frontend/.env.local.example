# Copy to `.env.local` (not committed). Optional for local Vite dev when using `npm run dev`:
# Leave unset to use relative /api URLs (Vite dev server proxies /api → FastAPI).

# Deployed SPA on Vercel — set same value in Vercel project Settings → Environment Variables:
# Do not wrap the URL in quotes.
# Example:
VITE_API_BASE_URL=https://your-backend.onrender.com
