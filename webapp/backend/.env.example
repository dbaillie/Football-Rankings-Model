# Copy to `.env` in repo root or next to the app (do not commit secrets).
#
# Supabase: Project Settings -> Database -> Connection string (URI).
# Use "Session" pool for SQLAlchemy if offered (port 5432 or pooled hostname).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

# Optional: still used when data_backend is csv_files
# FOOTBALL_OUTPUT_EUROPE_DIR=C:/path/to/europe

# Slim CSV / Postgres imports often drop 2024; default visibility years include 2024 and then
# no club passes the gate (GET /api/country/.../top-timeseries 404). Match years you ship:
# FOOTBALL_CLUB_VISIBILITY_YEARS=2025,2026

# Weekly ratings: leave UNSET to load full history from fr_weekly_ratings / europe_weekly_ratings.csv.
# Set to a positive integer N to load only the last N calendar years (saves RAM on tiny hosts).
# FOOTBALL_LOAD_LAST_CALENDAR_YEARS=
